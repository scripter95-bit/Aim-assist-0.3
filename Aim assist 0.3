local Players = game:GetService("Players")
local RunService = game:GetService("RunService")
local UIS = game:GetService("UserInputService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- SETTINGS
local aimEnabled = false
local aimStrength = 0.1
local aimPart = "Head" -- Head or HumanoidRootPart

-- UI
local gui = Instance.new("ScreenGui", player:WaitForChild("PlayerGui"))
gui.Name = "AimUI"
gui.ResetOnSpawn = false

local frame = Instance.new("Frame", gui)
frame.Size = UDim2.new(0, 200, 0, 180)
frame.Position = UDim2.new(0, 50, 0, 200)
frame.BackgroundColor3 = Color3.fromRGB(25,25,25)
frame.Active = true
frame.Draggable = true -- safe draggable

local function makeButton(text, posY)
	local btn = Instance.new("TextButton", frame)
	btn.Size = UDim2.new(0, 160, 0, 30)
	btn.Position = UDim2.new(0, 20, 0, posY)
	btn.Text = text
	btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
	btn.TextColor3 = Color3.new(1,1,1)
	return btn
end

-- Toggle
local toggleBtn = makeButton("Aim: OFF", 10)
toggleBtn.MouseButton1Click:Connect(function()
	aimEnabled = not aimEnabled
	toggleBtn.Text = "Aim: " .. (aimEnabled and "ON" or "OFF")
end)

-- Strength
local strengthBtn = makeButton("Strength: 0.1", 50)
strengthBtn.MouseButton1Click:Connect(function()
	if aimStrength == 0.10 then
		aimStrength = 3
	else
		aimStrength = 0.1
	end
	strengthBtn.Text = "Strength: " .. aimStrength
end)

-- Target Part
local partBtn = makeButton("Target: Head", 90)
partBtn.MouseButton1Click:Connect(function()
	if aimPart == "Head" then
		aimPart = "HumanoidRootPart"
	else
		aimPart = "Head"
	end
	partBtn.Text = "Target: " .. (aimPart == "Head" and "Head" or "Body")
end)

-- Close/Open
local openBtn = Instance.new("TextButton", gui)
openBtn.Size = UDim2.new(0, 60, 0, 30)
openBtn.Position = UDim2.new(0, 10, 0, 10)
openBtn.Text = "Open"
openBtn.Visible = false

local closeBtn = makeButton("Close", 130)

closeBtn.MouseButton1Click:Connect(function()
	frame.Visible = false
	openBtn.Visible = true
end)

openBtn.MouseButton1Click:Connect(function()
	frame.Visible = true
	openBtn.Visible = false
end)

-- GET TARGET
local function getClosestPlayer()
	local closest = nil
	local shortest = math.huge

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			local char = plr.Character
			local humanoid = char:FindFirstChild("Humanoid")
			local part = char:FindFirstChild(aimPart)

			if humanoid and humanoid.Health > 0 and part then
				local pos, visible = camera:WorldToViewportPoint(part.Position)
				if visible then
					local dist = (Vector2.new(pos.X, pos.Y) - UIS:GetMouseLocation()).Magnitude
					if dist < shortest then
						shortest = dist
						closest = part
					end
				end
			end
		end
	end

	return closest
end

-- AIM LOOP
RunService.RenderStepped:Connect(function()
	if aimEnabled then
		local target = getClosestPlayer()

		if target then
			camera.CFrame = camera.CFrame:Lerp(
				CFrame.new(camera.CFrame.Position, target.Position),
				aimStrength
			)
		end
	end
end)
