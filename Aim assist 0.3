local Players = game:GetService("Players")
local RunService = game:GetService("RunService")

local player = Players.LocalPlayer
local camera = workspace.CurrentCamera

-- ======================
-- SETTINGS
-- ======================
local aimEnabled = true
local aimStrength = 0.10
local MIN, MAX = 0.10, 0.15
local STEP = 0.01

local aimPart = "Head"

-- ======================
-- FRONT CHECK
-- ======================
local function isInFront(targetPart)
	local camLook = camera.CFrame.LookVector
	local toTarget = (targetPart.Position - camera.CFrame.Position).Unit
	return camLook:Dot(toTarget) > 0.3
end

-- ======================
-- TARGET SYSTEM (STABLE)
-- ======================
local function getTarget()
	local best
	local bestDist = math.huge

	for _, plr in pairs(Players:GetPlayers()) do
		if plr ~= player and plr.Character then
			local char = plr.Character
			local hum = char:FindFirstChild("Humanoid")
			local part = char:FindFirstChild(aimPart)

			if hum and hum.Health > 0 and part and isInFront(part) then
				local pos = camera:WorldToViewportPoint(part.Position)
				local dist = (Vector2.new(pos.X,pos.Y) - Vector2.new(camera.ViewportSize.X/2, camera.ViewportSize.Y/2)).Magnitude

				if dist < bestDist then
					bestDist = dist
					best = part
				end
			end
		end
	end

	return best
end

